include README.md
include DESIGN.md
include LICENSE
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include CMakeLists.txt
include cibuildwheel.toml

recursive-include src *.py
recursive-include native *.cpp *.hpp *.h
recursive-include tests *.py
recursive-include docs *.md *.png *.jpg *.jpeg *.gif *.svg *.txt *.py *.ipynb *.zip *.json *.csv *.yml *.yaml
recursive-include benchmarks *.py *.md *.json *.csv
recursive-include evals *.py *.md *.json
recursive-include examples *.py *.md *.ipynb *.csv *.json *.txt *.yml *.yaml

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
prune .pytest_cache
prune site
prune submission
exclude De-Time_Codex_task_list.md
exclude De-Time_final_checklist.md
exclude De-Time_JMLR_revision_plan.md
exclude AGENT_INPUT_CONTRACT.md
exclude AGENT_MANIFEST.json
exclude AGENT_MANIFEST.md
exclude JMLR_MLOSS_CHECKLIST.md
exclude JMLR_SOFTWARE_IMPROVEMENTS.md
prune docs/assets/generated/tutorials/visual-benchmark
exclude docs/tutorials/visual-benchmark.md
